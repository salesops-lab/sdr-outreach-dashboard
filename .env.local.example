# Copy to .env.local and fill in.

# HubSpot Private App token (Bearer). Needs read scopes for:
#   crm.objects.contacts.read, crm.objects.companies.read,
#   and engagement (calls/emails) read + associations.read
HUBSPOT_PAT=pat-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional — enables no-redeploy refresh via Vercel Blob.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
